{% if ansible_facts['distribution'] == "MacOSX" %}
# Homebrew bash completion is not built-in and needs to be sourced first
source $(brew --prefix)/etc/bash_completion.d/kubectl
{% endif %}

# Common Settings
export PS1="\u@\h:\w\$ "

if which nvim > /dev/null 2> /dev/null; then
  export EDITOR=nvim
else
  export EDITOR=vim
fi

if which fzf > /dev/null 2> /dev/null; then
  FZF_ALT_C_COMMAND= eval "$(fzf --bash)"
fi

if which archetect > /dev/null 2> /dev/null; then
  eval "$(archetect completions bash)"
fi

if which chainsaw > /dev/null 2> /dev/null; then
    eval "$(chainsaw completion bash)"
fi

[ -f ~/.aliases ] && source ~/.aliases
complete -o default -F __start_kubectl k

[ -f ~/.secrets ] && source ~/.secrets

{% if ansible_local.identity.purpose == "work" %}
# Work Settings

# Add alias for local plugin development with claude code.
alias claudep="claude $(find ~/orgs/p6m-run/claude-plugins/plugins -type d -depth 1 -exec echo -n '--plugin-dir {} ' \;)"
{% endif %}

if command -v wt >/dev/null 2>&1; then eval "$(command wt config shell init bash)"; fi
