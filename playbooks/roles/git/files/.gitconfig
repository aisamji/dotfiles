[user]
  name = Ali Samji
[core]
	editor = nvim
	excludesFile = ~/.gitignore
[pull]
	rebase = true
[init]
	defaultBranch = main
[url "git@github.com:"]
	insteadOf = https://github.com/
[url "git@github.com:"]
	insteadOf = gh:
[push]
  autoSetupRemote = true
  followTags = true
[gc]
  worktreePruneExpire = 1.day.ago
[include] ; purpose-specific settings
  path = ~/.gitconfig.d/default

