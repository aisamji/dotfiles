{
  "permissions": {
    "allow": [
{% if purpose == "work" %}
      "Skill(ybor-standards:git)",
      "Bash(acli jira workitem view:*)",
{% endif %}
      "Bash(kubectl get:*)",
      "Bash(kubectl describe:*)",
      "Bash(kubectl logs:*)",
      "Bash(kubectl api-resources:*)",
      "Bash(grep:*)",
      "Bash(awk:*)",
      "Bash(sort:*)",
      "Bash(rg:*)",
      "Bash(crossplane beta trace:*)",
      "Bash(cargo check:*)",
      "WebSearch",
      "Bash(kubectl config get-contexts:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(gh pr:*)",
      "Bash(jq:*)",
      "Bash(yq:*)"
    ],
    "deny": [
      "Bash(kubectl get secret:*)",
      "Bash(find:*)",
      "Bash(python:*)",
      "Bash(cat:*)",
      "Bash(gh pr merge:*)",
      "Bash(gh pr close:*)"
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "input=$(cat); cwd=$(echo \"$input\" | jq -r '.cwd'); model=$(echo \"$input\" | jq -r '.model.display_name'); used=$(echo \"$input\" | jq -r '.context_window.used_percentage // empty'); total_tok=$(echo \"$input\" | jq -r '.context_window.context_window_size // empty'); all_tok=$(echo \"$input\" | jq -r '(.context_window.current_usage.input_tokens // 0) + (.context_window.current_usage.output_tokens // 0) + (.context_window.current_usage.cache_read_input_tokens // 0) + (.context_window.current_usage.cache_creation_input_tokens // 0)'); if [ -n \"$used\" ] && [ -n \"$total_tok\" ] && [ \"$all_tok\" != \"0\" ]; then pct=$(printf '%.0f' \"$used\"); used_k=$(printf '%.0f' $(echo \"$all_tok\" | awk '{printf \"%f\", $1/1000}')); total_k=$(printf '%.0f' $(echo \"$total_tok\" | awk '{printf \"%f\", $1/1000}')); ctx=$(printf '%s%% (%sk/%sk)' \"$pct\" \"$used_k\" \"$total_k\"); else ctx=\"n/a\"; fi; printf '%s | %s | ctx: %s' \"$cwd\" \"$model\" \"$ctx\""
  },
  "enabledPlugins": {
{% if purpose == "work" %}
    "pr-review-toolkit@claude-plugins-official": true,
    "ybor-standards@p6m-run-plugins": true
{% endif %}
    "cq@cq": true
  },
  "extraKnownMarketplaces": {
{% if purpose == "work" %}
    "p6m-run-plugins": {
      "source": {
        "source": "github",
        "repo": "p6m-run/claude-plugins"
      },
      "autoUpdate": true
    },
{% endif %}
    "cq": {
      "source": {
        "source": "github",
        "repo": "mozilla-ai/cq"
      }
    }
  },
  "effortLevel": "high",
  "model": "sonnet"
}
